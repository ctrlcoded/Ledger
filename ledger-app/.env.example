# ---- Database (Supabase / Supavisor) ----
# Application runtime — port 6543 = Supavisor TRANSACTION mode (prepare:false, multiplexed).
DATABASE_URL="postgres://postgres.[ref]:[pw]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres"
# Migrations only — port 5432 = SESSION mode. Never used by the app at runtime.
DIRECT_URL="postgres://postgres.[ref]:[pw]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ---- Supabase Auth (public — safe to expose) ----
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-key]"
# Server-only. Used by the account-deletion flow. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="[service-role-key]"

# ---- Rate limiting (Upstash Redis) — optional in local dev ----
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- Billing / webhooks ----
RAZORPAY_WEBHOOK_SECRET="[razorpay-webhook-secret]"

# ---- Cron ----
CRON_SECRET="[random-long-secret]"
