# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Patterns are unanchored so they also cover the app in ledger-app/.

# dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# testing
coverage/

# next.js / build output
.next/
out/
build/
dist/

# misc
.DS_Store
Thumbs.db
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# local env files (never commit real secrets — .env.example is the template)
.env
.env.local
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / tooling
.claude/
.idea/
.vscode/

# internal design/architecture docs (kept local, not published)
Backend_archi.MD
Design.MD
